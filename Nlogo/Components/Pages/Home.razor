@page "/ide"
@using Nlogo.Compiler
@using Nlogo.Services
@inject IJSRuntime JS
@inject ChallengeService ChallengeService
@inject NavigationManager Nav
@inject ClassroomClientService ClassroomClient
@implements IAsyncDisposable
@using Nlogo.Services;

<PageTitle>Logo IDE</PageTitle>

<!-- ═══════════════════════════ TOOLBAR ═══════════════════════════ -->
<MudPaper Elevation="3" Class="toolbar-bar d-flex align-center gap-2 pa-2" Square="true">

    <MudIcon Icon="@Icons.Material.Filled.Polyline" Color="Color.Primary" Class="ml-1" />
    <MudText Typo="Typo.h6" Color="Color.Primary" Class="mr-3">Logo IDE</MudText>

    <MudDivider Vertical="true" FlexItem="true" />

    <MudButton Variant="Variant.Filled"
               Color="Color.Success"
               StartIcon="@Icons.Material.Filled.PlayArrow"
               Disabled="@_isRunning"
               OnClick="RunCode">Run</MudButton>

    <MudButton Variant="Variant.Outlined"
               Color="Color.Error"
               StartIcon="@Icons.Material.Filled.Stop"
               Disabled="@(!_isRunning)"
               OnClick="StopCode">Stop</MudButton>

    <MudButton Variant="Variant.Outlined"
               Color="Color.Default"
               StartIcon="@Icons.Material.Filled.RestartAlt"
               OnClick="ClearCanvas">Clear</MudButton>
    <MudDivider Vertical="true" FlexItem="true" />

    <MudIconButton Icon="@Icons.Material.Filled.FolderOpen"
                   Title="Open file"
                   OnClick="OpenFile" />

    <MudIconButton Icon="@Icons.Material.Filled.Save"
                   Title="Save (overwrites current file)"
                   OnClick="SaveFile" />

    <MudIconButton Icon="@Icons.Material.Filled.DriveFolderUpload"
                   Title="Save As…"
                   OnClick="SaveFileAs" />
    <MudDivider Vertical="true" FlexItem="true" />

    <MudIcon Icon="@Icons.Material.Filled.Speed" Size="Size.Small" />
    <MudText Typo="Typo.caption" Class="mr-1">Speed</MudText>
    <MudSlider T="int" @bind-Value="_speed" Min="1" Max="10"
               Color="Color.Primary" Style="width:130px; margin-bottom:0" />
    <MudText Typo="Typo.caption">@_speed</MudText>

    <MudDivider Vertical="true" FlexItem="true" />

    <!-- ── Challenge toggle ── -->
    <MudButton Variant="@(_challengePanelOpen? Variant.Filled: Variant.Outlined)"
               Color="Color.Secondary"
               StartIcon="@Icons.Material.Filled.School"
               OnClick="ToggleChallengePanel">
        Challenges
        @if (ChallengeService.TotalStars > 0)
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Warning"
                     Class="ml-1" Style="height:18px;font-size:0.65rem">
                ⭐ @ChallengeService.TotalStars
            </MudChip>
        }
    </MudButton>
    <MudDivider Vertical="true" FlexItem="true" />

    <!-- ── Examples menu ── -->
    <MudMenu Label="Examples" Variant="Variant.Outlined" Color="Color.Info"
             StartIcon="@Icons.Material.Filled.AutoAwesome"
             AnchorOrigin="Origin.BottomLeft" TransformOrigin="Origin.TopLeft">
        @foreach (var ex in _examples)
        {
            var captured = ex;
            <MudMenuItem OnClick="@(() => LoadExample(captured))">
                <div style="display:flex; flex-direction:column; gap:2px">
                    <span>@captured.Emoji &nbsp;<strong>@captured.Title</strong></span>
                    <span style="font-size:0.72rem; opacity:0.65">@captured.Description</span>
                </div>
            </MudMenuItem>
        }
    </MudMenu>
    <!-- ── Turtle shape picker ── -->
    <MudMenu Label="@TurtleShapeLabel"
             Variant="Variant.Outlined"
             Color="Color.Tertiary"
             StartIcon="@Icons.Material.Filled.Pets"
             AnchorOrigin="Origin.BottomLeft"
             TransformOrigin="Origin.TopLeft"
             Title="Change turtle appearance">

        <MudMenuItem Disabled="true">
            <MudText Typo="Typo.caption" Color="Color.Secondary">— Shapes —</MudText>
        </MudMenuItem>
        @foreach (var shape in TurtleShapes.Where(s => !s.Id.StartsWith("emoji:")))
        {
            var captured = shape;
            <MudMenuItem OnClick="@(() => SetTurtleShape(captured.Id))">
                <span style="display:flex; align-items:center; gap:8px">
                    <span style="font-size:1.2rem">@captured.Emoji</span>
                    <strong>@captured.Label</strong>
                </span>
            </MudMenuItem>
        }

        <MudMenuItem Disabled="true">
            <MudText Typo="Typo.caption" Color="Color.Secondary">— Emoji —</MudText>
        </MudMenuItem>
        @foreach (var shape in TurtleShapes.Where(s => s.Id.StartsWith("emoji:")))
        {
            var captured = shape;
            <MudMenuItem OnClick="@(() => SetTurtleShape(captured.Id))">
                <span style="display:flex; align-items:center; gap:8px">
                    <span style="font-size:1.3rem">@captured.Emoji</span>
                    <strong>@captured.Label</strong>
                </span>
            </MudMenuItem>
        }
    </MudMenu>
    <MudSpacer />
    <MudIconButton Icon="@Icons.Material.Filled.Home"
                   Title="Back to menu"
                   OnClick="@(() => Nav.NavigateTo("/"))" />

    @if (ClassroomClient.IsConnected)
    {
        <MudChip T="string" Color="Color.Success" Size="Size.Small"
                 Icon="@Icons.Material.Filled.Wifi" Class="mr-1">
            Live class
        </MudChip>
    }

    <MudChip T="string" Color="Color.Dark" Size="Size.Small" Icon="@Icons.Material.Filled.Info">
        @_statusMessage
    </MudChip>

</MudPaper>

<!-- ═══════════════════════════ MAIN SPLIT ═══════════════════════════ -->
<div class="ide-body">

    <!-- ── LEFT COLUMN: editor + console stacked ── -->
    <div class="left-column" id="leftColumn">

        <!-- Challenge panel slides over the editor -->
        <ChallengePanel JsModule="@_jsModule"
                        IsOpen="@_challengePanelOpen"
                        OnClose="@(() => _challengePanelOpen = false)"
                        OnLoadCode="@LoadStarterCode" />

        <!-- Editor pane -->
        <div class="editor-pane">
            <div class="pane-header">
                <MudIcon Icon="@Icons.Material.Filled.Code" Size="Size.Small" />
                <MudText Typo="Typo.caption" Class="ml-1">@CurrentFileName</MudText>
                <MudSpacer />
                <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                               Size="Size.Small" Title="Copy code"
                               OnClick="CopyCode" />
                <MudIconButton Icon="@Icons.Material.Filled.DeleteForever"
                               Size="Size.Small" Title="Clear editor"
                               Color="Color.Error"
                               OnClick="ClearEditor" />

            </div>

            <div class="mirror-wrapper">
                <div id="lineNumbers"></div>
                <div class="editor-scroll-area">
                    <pre id="highlightLayer" class="highlight-layer" aria-hidden="true"><code id="highlightCode"></code></pre>
                    <textarea id="codeEditor"
                              class="code-editor"
                              spellcheck="false"
                              placeholder="; Write Logo code here..."></textarea>
                </div>
            </div>
        </div>

        <!-- Console pane -->
        <div class="console-pane">
            <div class="d-flex align-center px-2 pt-1">
                <MudIcon Icon="@Icons.Material.Filled.Terminal" Size="Size.Small" />
                <MudText Typo="Typo.caption" Class="ml-1">Output</MudText>
                <MudSpacer />
                <MudIconButton Icon="@Icons.Material.Filled.DeleteSweep"
                               Size="Size.Small" Title="Clear console"
                               OnClick="() => _consoleLines.Clear()" />
            </div>
            <div class="console-output" id="consoleOutput">
                @foreach (var line in _consoleLines)
                {
                    <div class="@(line.IsError ? "con-error" : line.IsSystem ? "con-system" : "con-normal")">
                        <span class="con-prefix">@line.Prefix</span>@line.Text
                    </div>
                }
            </div>
        </div>

    </div>

    <!-- ── RESIZE HANDLE ── -->
    <div class="resize-handle" id="resizeHandle">
        <div class="resize-grip"></div>
    </div>

    <!-- ── CANVAS PANE ── -->
    <div class="canvas-pane" id="canvasPane">
        <div class="pane-header">
            <MudIcon Icon="@Icons.Material.Filled.Brush" Size="Size.Small" />
            <MudText Typo="Typo.caption" Class="ml-1">Canvas</MudText>
            <MudSpacer />
            <MudIconButton Icon="@Icons.Material.Filled.Download"
                           Size="Size.Small" Title="Save image"
                           OnClick="SaveCanvas" />
        </div>
        <div class="canvas-wrapper">
            <canvas id="turtleCanvas"></canvas>
        </div>
    </div>

</div>

@code {

    private static readonly (string Id, string Emoji, string Label)[] TurtleShapes =
    [
        // ── Classic shapes
        ("arrow",  "🔺", "Arrow"),
    ("turtle", "🐢", "Turtle"),
    ("dot",    "⭕", "Dot"),
    ("rocket", "🚀", "Rocket"),
    ("bug",    "🐛", "Bug"),
    // ── Emoji shapes
    ("emoji:💩", "💩", "Poo"),
    ("emoji:👾", "👾", "Alien"),
    ("emoji:🦆", "🦆", "Duck"),
    ("emoji:🐸", "🐸", "Frog"),
    ("emoji:👻", "👻", "Ghost"),
    ("emoji:🤖", "🤖", "Robot"),
    ("emoji:🦄", "🦄", "Unicorn"),
    ("emoji:⭐", "⭐", "Star"),
    ("emoji:🦖", "🦖", "Dino"),
    ("emoji:🐙", "🐙", "Octopus"),
    ("emoji:🍕", "🍕", "Pizza"),
    ("emoji:🎃", "🎃", "Pumpkin"),
];

    // ── File state ──────────────────────────────────────────────────
    private string? _currentFilePath;

    private string CurrentFileName =>
      _currentFilePath is not null
          ? Path.GetFileName(_currentFilePath)
          : "untitled.nlogo";

    // ── State ──────────────────────────────────────────────────────
    private int _speed = 5;
    private bool _isRunning = false;
    private bool _challengePanelOpen = false;
    private string _statusMessage = "Ready";

    private readonly List<ConsoleLine> _consoleLines = new();
    private IJSObjectReference? _jsModule;
    private CancellationTokenSource? _cts;


    // ── Turtle shape picker ────────────────────────────────────────
   

    private string _turtleShape = "arrow";

    private string TurtleShapeLabel
    {
        get
        {
            var s = TurtleShapes.FirstOrDefault(x => x.Id == _turtleShape);
            return s == default ? "🔺 Arrow" : $"{s.Emoji} {s.Label}";
        }
    }

    private async Task SetTurtleShape(string shapeId)
    {
        _turtleShape = shapeId;
        if (_jsModule is not null)
            await _jsModule.InvokeVoidAsync("setTurtleShape", shapeId);
    }




    // ── Lifecycle ──────────────────────────────────────────────────
    protected override void OnInitialized()
    {
        ChallengeService.ProgressChanged  += OnProgressChanged;
        ClassroomClient.StateChanged      += OnClassroomStateChanged;
    }

    private void OnProgressChanged() => InvokeAsync(StateHasChanged);
    private void OnClassroomStateChanged() => InvokeAsync(StateHasChanged);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _jsModule = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./js/ideInterop.js");

            await _jsModule.InvokeVoidAsync("initCanvas", "turtleCanvas");
            await _jsModule.InvokeVoidAsync("initEditor", "codeEditor");
            await _jsModule.InvokeVoidAsync("initResizer", "resizeHandle", "leftColumn", "canvasPane");

            // Load persisted progress — triggers ProgressChanged so the
            // toolbar star count and challenge panel unlock states update.
            await ChallengeService.EnsureLoadedAsync();
            StateHasChanged();

            Log("▶  Logo IDE ready.", isSystem: true);
        }
    }

    // ── Challenge panel ────────────────────────────────────────────
    private void ToggleChallengePanel()
        => _challengePanelOpen = !_challengePanelOpen;

    private async Task LoadStarterCode(string code)
    {
        if (_jsModule is not null)
            await _jsModule.InvokeVoidAsync("setEditorValue", code);
        _consoleLines.Clear();
        _statusMessage = "Ready";
    }

    // ── Run ────────────────────────────────────────────────────────
    private async Task RunCode()
    {
        if (_jsModule is null) { Log("Editor not ready.", isSystem: true); return; }

        var code = await _jsModule.InvokeAsync<string>("getEditorValue");
        if (string.IsNullOrWhiteSpace(code)) { Log("Nothing to run.", isSystem: true); return; }

        await _jsModule.InvokeVoidAsync("clearErrorLines");

        _cts           = new CancellationTokenSource();
        _isRunning     = true;
        _statusMessage = "Running...";
        _consoleLines.Clear();
        StateHasChanged();

        try
        {
            var lexer = new Lexer(code);
            lexer.Tokenise();
            if (lexer.HasErrors)
            {
                foreach (var e in lexer.Errors) Log(e, isError: true);
                await MarkErrorLinesAsync(lexer.Errors);
                return;
            }

            var parser = new Parser(lexer.Tokens);
            var ast = parser.Parse();
            if (parser.HasErrors)
            {
                foreach (var e in parser.Errors) Log(e, isError: true);
                await MarkErrorLinesAsync(parser.Errors);
                return;
            }

            var interpreter = new Interpreter(
                js: _jsModule,
                log: msg => Log(msg),
                logError: msg => Log(msg, isError: true),
                ct: _cts.Token,
                speed: _speed);

            await interpreter.RunAsync(ast);

            _statusMessage = "Done";
            Log("✔ Done.", isSystem: true);
        }
        catch (OperationCanceledException)
        {
            _statusMessage = "Stopped";
            Log("⏹ Stopped.", isSystem: true);
        }
        catch (RuntimeException ex)
        {
            _statusMessage = "Runtime error";
            Log(ex.Message, isError: true);
            await MarkErrorLinesAsync(new[] { ex.Message });
        }
        catch (Exception ex)
        {
            _statusMessage = "Error";
            Log($"Unexpected error: {ex.Message}", isError: true);
        }
        finally
        {
            _isRunning = false;
            _cts?.Dispose();
            _cts = null;
            StateHasChanged();
        }
    }

    private async Task MarkErrorLinesAsync(IEnumerable<string> errors)
    {
        if (_jsModule is null) return;
        var lines = new List<int>();
        foreach (var msg in errors)
        {
            var m = System.Text.RegularExpressions.Regex.Match(msg, @"Line\s+(\d+)");
            if (m.Success && int.TryParse(m.Groups[1].Value, out int ln))
                lines.Add(ln);
        }
        if (lines.Count > 0)
            await _jsModule.InvokeVoidAsync("setErrorLines", lines.Distinct().ToArray());
    }

    // ── Toolbar actions ────────────────────────────────────────────
    private void StopCode() => _cts?.Cancel();

    private async Task ClearCanvas()
    {
        if (_jsModule is not null)
            await _jsModule.InvokeVoidAsync("clearCanvas");
        _statusMessage = "Ready";
        Log("Canvas cleared.", isSystem: true);
    }

    private async Task CopyCode()
    {
        if (_jsModule is not null)
        {
            var code = await _jsModule.InvokeAsync<string>("getEditorValue");
            await _jsModule.InvokeVoidAsync("copyToClipboard", code);
        }
    }

    private async Task SaveCanvas()
    {
        if (_jsModule is not null)
            await _jsModule.InvokeVoidAsync("saveCanvasImage", "logo-drawing.png");
    }

    // ── Console helpers ────────────────────────────────────────────
    private void Log(string text, bool isError = false, bool isSystem = false)
    {
        _consoleLines.Add(new ConsoleLine(
            Text: text,
            Prefix: isSystem ? "» " : isError ? "✖ " : "  ",
            IsError: isError,
            IsSystem: isSystem));
        StateHasChanged();
    }

    // ── Cleanup ────────────────────────────────────────────────────
    public async ValueTask DisposeAsync()
    {
        ChallengeService.ProgressChanged -= OnProgressChanged;
        ClassroomClient.StateChanged     -= OnClassroomStateChanged;

        if (_jsModule is not null)
            await _jsModule.DisposeAsync();
    }

    private record ConsoleLine(
        string Text,
        string Prefix = "  ",
        bool IsError = false,
        bool IsSystem = false);

    // ── Open ────────────────────────────────────────────────────────
    private async Task OpenFile()
    {
        var result = await FilePicker.PickAsync(new PickOptions
        {
            PickerTitle = "Open NLogo source file",
            FileTypes = new FilePickerFileType(
                new Dictionary<DevicePlatform, IEnumerable<string>>
                {
                { DevicePlatform.WinUI,   new[] { ".nlogo", ".logo" } },
                { DevicePlatform.macOS,   new[] { "nlogo",  "logo"  } },
                { DevicePlatform.Android, new[] { "application/octet-stream" } },
                { DevicePlatform.iOS,     new[] { "public.data" } },
                })
        });

        if (result is null) return;

        // Extra guard — reject anything that slipped past the picker filter
        if (!NLogoFileFormat.IsSupported(result.FullPath))
        {
            Log("❌ Unsupported file type. Please open a .nlogo file.", isError: true);
            return;
        }

        try
        {
            var raw = await File.ReadAllTextAsync(result.FullPath);
            var ext = Path.GetExtension(result.FullPath);
            var parsed = NLogoFileFormat.Unwrap(raw, ext);

            if (!parsed.Valid)
            {
                Log($"❌ {parsed.Warning}", isError: true);
                return;
            }

            _currentFilePath = result.FullPath;

            if (_jsModule is not null)
                await _jsModule.InvokeVoidAsync("setEditorValue", parsed.Code ?? string.Empty);

            _consoleLines.Clear();
            _statusMessage = "Ready";
            Log($"📂 Opened: {CurrentFileName}", isSystem: true);

            if (parsed.Warning is not null)
                Log(parsed.Warning, isError: true);   // checksum mismatch — non-fatal

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Log($"Could not open file: {ex.Message}", isError: true);
        }
    }

    // ── Save (overwrite) ────────────────────────────────────────────
    private async Task SaveFile()
    {
        if (_currentFilePath is null) { await SaveFileAs(); return; }

        // Ensure the current path has the right extension (upgrade .logo → .nlogo)
        if (!Path.GetExtension(_currentFilePath)
                .Equals(NLogoFileFormat.Extension, StringComparison.OrdinalIgnoreCase))
        {
            _currentFilePath = Path.ChangeExtension(
                _currentFilePath, NLogoFileFormat.Extension);
        }

        try
        {
            var code = _jsModule is not null
                          ? await _jsModule.InvokeAsync<string>("getEditorValue")
                          : string.Empty;

            var wrapped = NLogoFileFormat.Wrap(code);
            await File.WriteAllTextAsync(_currentFilePath, wrapped);
            _statusMessage = "Saved";
            Log($"💾 Saved: {CurrentFileName}", isSystem: true);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Log($"Could not save file: {ex.Message}", isError: true);
        }
    }
    // ── Save As ─────────────────────────────────────────────────────
    private async Task SaveFileAs()
    {
        var code = _jsModule is not null
            ? await _jsModule.InvokeAsync<string>("getEditorValue")
            : string.Empty;

        var wrapped = NLogoFileFormat.Wrap(code);
#if WINDOWS
try
{
var picker = new Windows.Storage.Pickers.FileSavePicker();
        var win = Application.Current?.Windows[0]?.Handler?.PlatformView
                  as Microsoft.UI.Xaml.Window;
        if (win is not null)
            WinRT.Interop.InitializeWithWindow.Initialize(
                picker, WinRT.Interop.WindowNative.GetWindowHandle(win));

        picker.SuggestedStartLocation =
            Windows.Storage.Pickers.PickerLocationId.DocumentsLibrary;
        picker.FileTypeChoices.Add("NLogo Source File", new List<string> { ".nlogo" });
        picker.SuggestedFileName = Path.GetFileNameWithoutExtension(CurrentFileName);

        var file = await picker.PickSaveFileAsync();
        if (file is null) return;

        await Windows.Storage.FileIO.WriteTextAsync(file, wrapped);
        _currentFilePath = file.Path;
        _statusMessage = "Saved";
        Log($"💾 Saved: {CurrentFileName}", isSystem: true);
        StateHasChanged();
    }
    catch (Exception ex)
    {
        Log($"Could not save file: {ex.Message}", isError: true);
    }
#else
        try
        {
            var docs = Environment.GetFolderPath(Environment.SpecialFolder.MyDocuments);
            var name = Path.ChangeExtension(CurrentFileName, NLogoFileFormat.Extension);
            var path = Path.Combine(docs, name);
            await File.WriteAllTextAsync(path, wrapped);
            _currentFilePath = path;
            _statusMessage = "Saved";
            Log($"💾 Saved to: {path}", isSystem: true);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Log($"Could not save file: {ex.Message}", isError: true);
        }
#endif
    }
    // ── Example snippets ───────────────────────────────────────────
    private record SnippetExample(string Emoji, string Title, string Description, string Code);

    private static readonly IReadOnlyList<SnippetExample> _examples =
    [
        new("🔷", "Square",
        "Basic movement and REPEAT",
        """
        ; 🔷 Square
        ; Move forward and turn right 4 times to draw a square.
        ; Try changing the 100 to make it bigger or smaller!

        REPEAT 4 [
          FD 100
          RT 90
        ]
        """),

    new("🌀", "Spiral",
        "Variables that grow with each step",
        """
        ; 🌀 Spiral
        ; The turtle moves a little further each time,
        ; creating an expanding spiral.

        MAKE "size 5

        REPEAT 80 [
          FD :size
          RT 31
          MAKE "size :size + 3
        ]
        """),

    new("🔵", "Spinning Squares",
        "Nested loops to build patterns",
        """
        ; 🔵 Spinning Squares
        ; Draw a square, rotate a little, repeat 18 times.
        ; Watch the pattern build up!

        REPEAT 18 [
          REPEAT 4 [
            FD 100
            RT 90
          ]
          RT 20
        ]
        """),

    new("🌈", "Rainbow Star",
        "Colours and geometry combined",
        """
        ; 🌈 Rainbow Star
        ; Each point of the star is a different colour.
        ; A 5-pointed star turns 144 degrees at each tip.

        SETCOLOR "red
        FD 150  RT 144
        SETCOLOR "orange
        FD 150  RT 144
        SETCOLOR "yellow
        FD 150  RT 144
        SETCOLOR "green
        FD 150  RT 144
        SETCOLOR "blue
        FD 150  RT 144
        """),

    new("🌲", "Fractal Tree",
        "Recursion with TO and END",
        """
        ; 🌲 Fractal Tree
        ; The TREE procedure calls itself to draw branches.
        ; Each branch is 70% the size of its parent.

        TO TREE :size
          IF :size < 5 [ STOP ]
          FD :size
          RT 25
          TREE :size * 0.7
          LT 50
          TREE :size * 0.7
          RT 25
          BK :size
        END

        ; Start drawing — try changing 80 for a bigger/smaller tree
        TREE 80
        """),

    new("🔶", "Polygon Maker",
        "Procedures with parameters",
        """
        ; 🔶 Polygon Maker
        ; POLYGON draws any regular shape.
        ; It takes two inputs: number of sides, and side length.

        TO POLYGON :sides :size
          REPEAT :sides [
            FD :size
            RT 360 / :sides
          ]
        END

        ; Draw a triangle, pentagon, and octagon
        SETCOLOR "red
        POLYGON 3 90

        HOME
        SETCOLOR "blue
        POLYGON 5 70

        HOME
        SETCOLOR "green
        POLYGON 8 55
        """),
];

    private async Task LoadExample(SnippetExample example)
    {
        if (_jsModule is null) return;

        // Strip the C# raw-string indentation so the editor looks clean
        var lines = example.Code.Split('\n');
        var indent = lines
            .Where(l => l.Trim().Length > 0)
            .Select(l => l.Length - l.TrimStart().Length)
            .DefaultIfEmpty(0)
            .Min();

        var cleaned = string.Join('\n', lines.Select(l =>
            l.Length >= indent ? l[indent..] : l)).Trim();

        await _jsModule.InvokeVoidAsync("setEditorValue", cleaned);
        _consoleLines.Clear();
        _statusMessage = "Ready";
        _currentFilePath = null;   // treat as an unsaved new file
        Log($"📋 Loaded example: {example.Emoji} {example.Title}", isSystem: true);
        StateHasChanged();
    }
    private async Task ClearEditor()
    {
        if (_jsModule is null) return;

        // Confirm before wiping — students will thank you
        bool confirmed = await JS.InvokeAsync<bool>(
            "confirm", "Clear the editor? Any unsaved code will be lost.");
        if (!confirmed) return;

        await _jsModule.InvokeVoidAsync("setEditorValue", string.Empty);
        _currentFilePath = null;          // treat as a fresh unsaved file
        _consoleLines.Clear();
        _statusMessage = "Ready";
        Log("Editor cleared.", isSystem: true);
        StateHasChanged();
    }
}
