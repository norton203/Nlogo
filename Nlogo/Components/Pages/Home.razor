@page "/"
@using Nlogo.Compiler
@using Nlogo.Services
@inject IJSRuntime JS
@inject ChallengeService ChallengeService
@implements IAsyncDisposable

<PageTitle>Logo IDE</PageTitle>

<!-- ═══════════════════════════ TOOLBAR ═══════════════════════════ -->
<MudPaper Elevation="3" Class="toolbar-bar d-flex align-center gap-2 pa-2" Square="true">

    <MudIcon Icon="@Icons.Material.Filled.Polyline" Color="Color.Primary" Class="ml-1" />
    <MudText Typo="Typo.h6" Color="Color.Primary" Class="mr-3">Logo IDE</MudText>

    <MudDivider Vertical="true" FlexItem="true" />

    <MudButton Variant="Variant.Filled"
               Color="Color.Success"
               StartIcon="@Icons.Material.Filled.PlayArrow"
               Disabled="@_isRunning"
               OnClick="RunCode">Run</MudButton>

    <MudButton Variant="Variant.Outlined"
               Color="Color.Error"
               StartIcon="@Icons.Material.Filled.Stop"
               Disabled="@(!_isRunning)"
               OnClick="StopCode">Stop</MudButton>

    <MudButton Variant="Variant.Outlined"
               Color="Color.Default"
               StartIcon="@Icons.Material.Filled.RestartAlt"
               OnClick="ClearCanvas">Clear</MudButton>

    <MudDivider Vertical="true" FlexItem="true" />

    <MudIcon Icon="@Icons.Material.Filled.Speed" Size="Size.Small" />
    <MudText Typo="Typo.caption" Class="mr-1">Speed</MudText>
    <MudSlider T="int" @bind-Value="_speed" Min="1" Max="10"
               Color="Color.Primary" Style="width:130px; margin-bottom:0" />
    <MudText Typo="Typo.caption">@_speed</MudText>

    <MudDivider Vertical="true" FlexItem="true" />

    <!-- ── Challenge toggle ── -->
    <MudButton Variant="@(_challengePanelOpen? Variant.Filled: Variant.Outlined)"
               Color="Color.Secondary"
               StartIcon="@Icons.Material.Filled.School"
               OnClick="ToggleChallengePanel">
        Challenges
        @if (ChallengeService.TotalStars > 0)
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Warning"
                     Class="ml-1" Style="height:18px;font-size:0.65rem">
                ⭐ @ChallengeService.TotalStars
            </MudChip>
        }
    </MudButton>

    <MudSpacer />

    <MudChip T="string" Color="Color.Dark" Size="Size.Small" Icon="@Icons.Material.Filled.Info">
        @_statusMessage
    </MudChip>

</MudPaper>

<!-- ═══════════════════════════ MAIN SPLIT ═══════════════════════════ -->
<div class="ide-body">

    <!-- ── LEFT COLUMN: editor + console stacked ── -->
    <div class="left-column" id="leftColumn">

        <!-- Challenge panel slides over the editor -->
        <ChallengePanel JsModule="@_jsModule"
                        IsOpen="@_challengePanelOpen"
                        OnClose="@(() => _challengePanelOpen = false)"
                        OnLoadCode="@LoadStarterCode" />

        <!-- Editor pane -->
        <div class="editor-pane">
            <div class="pane-header">
                <MudIcon Icon="@Icons.Material.Filled.Code" Size="Size.Small" />
                <MudText Typo="Typo.caption" Class="ml-1">Editor</MudText>
                <MudSpacer />
                <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                               Size="Size.Small" Title="Copy code"
                               OnClick="CopyCode" />
            </div>

            <div class="mirror-wrapper">
                <div id="lineNumbers"></div>
                <div class="editor-scroll-area">
                    <pre id="highlightLayer" class="highlight-layer" aria-hidden="true"><code id="highlightCode"></code></pre>
                    <textarea id="codeEditor"
                              class="code-editor"
                              spellcheck="false"
                              placeholder="; Write Logo code here..."></textarea>
                </div>
            </div>
        </div>

        <!-- Console pane -->
        <div class="console-pane">
            <div class="d-flex align-center px-2 pt-1">
                <MudIcon Icon="@Icons.Material.Filled.Terminal" Size="Size.Small" />
                <MudText Typo="Typo.caption" Class="ml-1">Output</MudText>
                <MudSpacer />
                <MudIconButton Icon="@Icons.Material.Filled.DeleteSweep"
                               Size="Size.Small" Title="Clear console"
                               OnClick="() => _consoleLines.Clear()" />
            </div>
            <div class="console-output" id="consoleOutput">
                @foreach (var line in _consoleLines)
                {
                    <div class="@(line.IsError ? "con-error" : line.IsSystem ? "con-system" : "con-normal")">
                        <span class="con-prefix">@line.Prefix</span>@line.Text
                    </div>
                }
            </div>
        </div>

    </div>

    <!-- ── RESIZE HANDLE ── -->
    <div class="resize-handle" id="resizeHandle">
        <div class="resize-grip"></div>
    </div>

    <!-- ── CANVAS PANE ── -->
    <div class="canvas-pane" id="canvasPane">
        <div class="pane-header">
            <MudIcon Icon="@Icons.Material.Filled.Brush" Size="Size.Small" />
            <MudText Typo="Typo.caption" Class="ml-1">Canvas</MudText>
            <MudSpacer />
            <MudIconButton Icon="@Icons.Material.Filled.Download"
                           Size="Size.Small" Title="Save image"
                           OnClick="SaveCanvas" />
        </div>
        <div class="canvas-wrapper">
            <canvas id="turtleCanvas"></canvas>
        </div>
    </div>

</div>

@code {

    // ── State ──────────────────────────────────────────────────────
    private int _speed = 5;
    private bool _isRunning = false;
    private bool _challengePanelOpen = false;
    private string _statusMessage = "Ready";

    private readonly List<ConsoleLine> _consoleLines = new();
    private IJSObjectReference? _jsModule;
    private CancellationTokenSource? _cts;

    // ── Lifecycle ──────────────────────────────────────────────────
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _jsModule = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./js/ideInterop.js");

            await _jsModule.InvokeVoidAsync("initCanvas", "turtleCanvas");
            await _jsModule.InvokeVoidAsync("initEditor", "codeEditor");
            await _jsModule.InvokeVoidAsync("initResizer", "resizeHandle", "leftColumn", "canvasPane");

            // Load persisted progress — triggers ProgressChanged so the
            // toolbar star count and challenge panel unlock states update.
            await ChallengeService.EnsureLoadedAsync();
            StateHasChanged();

            Log("▶  Logo IDE ready.", isSystem: true);
        }
    }

    // ── Challenge panel ────────────────────────────────────────────
    private void ToggleChallengePanel()
        => _challengePanelOpen = !_challengePanelOpen;

    private async Task LoadStarterCode(string code)
    {
        if (_jsModule is not null)
            await _jsModule.InvokeVoidAsync("setEditorValue", code);
        _consoleLines.Clear();
        _statusMessage = "Ready";
    }

    // ── Run ────────────────────────────────────────────────────────
    private async Task RunCode()
    {
        if (_jsModule is null) { Log("Editor not ready.", isSystem: true); return; }

        var code = await _jsModule.InvokeAsync<string>("getEditorValue");
        if (string.IsNullOrWhiteSpace(code)) { Log("Nothing to run.", isSystem: true); return; }

        await _jsModule.InvokeVoidAsync("clearErrorLines");

        _cts           = new CancellationTokenSource();
        _isRunning     = true;
        _statusMessage = "Running...";
        _consoleLines.Clear();
        StateHasChanged();

        try
        {
            var lexer = new Lexer(code);
            lexer.Tokenise();
            if (lexer.HasErrors)
            {
                foreach (var e in lexer.Errors) Log(e, isError: true);
                await MarkErrorLinesAsync(lexer.Errors);
                return;
            }

            var parser = new Parser(lexer.Tokens);
            var ast = parser.Parse();
            if (parser.HasErrors)
            {
                foreach (var e in parser.Errors) Log(e, isError: true);
                await MarkErrorLinesAsync(parser.Errors);
                return;
            }

            var interpreter = new Interpreter(
                js: _jsModule,
                log: msg => Log(msg),
                logError: msg => Log(msg, isError: true),
                ct: _cts.Token,
                speed: _speed);

            await interpreter.RunAsync(ast);

            _statusMessage = "Done";
            Log("✔ Done.", isSystem: true);
        }
        catch (OperationCanceledException)
        {
            _statusMessage = "Stopped";
            Log("⏹ Stopped.", isSystem: true);
        }
        catch (RuntimeException ex)
        {
            _statusMessage = "Runtime error";
            Log(ex.Message, isError: true);
            await MarkErrorLinesAsync(new[] { ex.Message });
        }
        catch (Exception ex)
        {
            _statusMessage = "Error";
            Log($"Unexpected error: {ex.Message}", isError: true);
        }
        finally
        {
            _isRunning = false;
            _cts?.Dispose();
            _cts = null;
            StateHasChanged();
        }
    }

    private async Task MarkErrorLinesAsync(IEnumerable<string> errors)
    {
        if (_jsModule is null) return;
        var lines = new List<int>();
        foreach (var msg in errors)
        {
            var m = System.Text.RegularExpressions.Regex.Match(msg, @"Line\s+(\d+)");
            if (m.Success && int.TryParse(m.Groups[1].Value, out int ln))
                lines.Add(ln);
        }
        if (lines.Count > 0)
            await _jsModule.InvokeVoidAsync("setErrorLines", lines.Distinct().ToArray());
    }

    // ── Toolbar actions ────────────────────────────────────────────
    private void StopCode() => _cts?.Cancel();

    private async Task ClearCanvas()
    {
        if (_jsModule is not null)
            await _jsModule.InvokeVoidAsync("clearCanvas");
        _statusMessage = "Ready";
        Log("Canvas cleared.", isSystem: true);
    }

    private async Task CopyCode()
    {
        if (_jsModule is not null)
        {
            var code = await _jsModule.InvokeAsync<string>("getEditorValue");
            await _jsModule.InvokeVoidAsync("copyToClipboard", code);
        }
    }

    private async Task SaveCanvas()
    {
        if (_jsModule is not null)
            await _jsModule.InvokeVoidAsync("saveCanvasImage", "logo-drawing.png");
    }

    // ── Console helpers ────────────────────────────────────────────
    private void Log(string text, bool isError = false, bool isSystem = false)
    {
        _consoleLines.Add(new ConsoleLine(
            Text: text,
            Prefix: isSystem ? "» " : isError ? "✖ " : "  ",
            IsError: isError,
            IsSystem: isSystem));
        StateHasChanged();
    }

    // ── Cleanup ────────────────────────────────────────────────────
    public async ValueTask DisposeAsync()
    {
        if (_jsModule is not null)
            await _jsModule.DisposeAsync();
    }

    private record ConsoleLine(
        string Text,
        string Prefix = "  ",
        bool IsError = false,
        bool IsSystem = false);
}
