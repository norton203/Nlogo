@page "/"
@using Nlogo.Compiler
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Logo IDE</PageTitle>

<!-- ═══════════════════════════ TOOLBAR ═══════════════════════════ -->
<MudPaper Elevation="3" Class="toolbar-bar d-flex align-center gap-2 pa-2" Square="true">

    <MudIcon Icon="@Icons.Material.Filled.Polyline" Color="Color.Primary" Class="ml-1" />
    <MudText Typo="Typo.h6" Color="Color.Primary" Class="mr-3">Logo IDE</MudText>

    <MudDivider Vertical="true" FlexItem="true" />

    <MudButton Variant="Variant.Filled"
               Color="Color.Success"
               StartIcon="@Icons.Material.Filled.PlayArrow"
               Disabled="@_isRunning"
               OnClick="RunCode">Run</MudButton>

    <MudButton Variant="Variant.Outlined"
               Color="Color.Error"
               StartIcon="@Icons.Material.Filled.Stop"
               Disabled="@(!_isRunning)"
               OnClick="StopCode">Stop</MudButton>

    <MudButton Variant="Variant.Outlined"
               Color="Color.Default"
               StartIcon="@Icons.Material.Filled.RestartAlt"
               OnClick="ClearCanvas">Clear</MudButton>

    <MudDivider Vertical="true" FlexItem="true" />

    <MudIcon Icon="@Icons.Material.Filled.Speed" Size="Size.Small" />
    <MudText Typo="Typo.caption" Class="mr-1">Speed</MudText>
    <MudSlider T="int" @bind-Value="_speed" Min="1" Max="10"
               Color="Color.Primary" Style="width:130px; margin-bottom:0" />
    <MudText Typo="Typo.caption">@_speed</MudText>

    <MudSpacer />

    <MudChip T="string" Color="Color.Dark" Size="Size.Small" Icon="@Icons.Material.Filled.Info">
        @_statusMessage
    </MudChip>

</MudPaper>

<!-- ═══════════════════════════ MAIN SPLIT ═══════════════════════════ -->
<div class="ide-body">

        <!-- ── EDITOR PANE ── -->
<div class="editor-pane" id="editorPane">
    <div class="pane-header">
        <MudIcon Icon="@Icons.Material.Filled.Code" Size="Size.Small" />
        <MudText Typo="Typo.caption" Class="ml-1">Editor</MudText>
        <MudSpacer />
        <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                       Size="Size.Small" Title="Copy code"
                       OnClick="CopyCode" />
    </div>

    <!-- Mirror wrapper: pre sits behind, textarea floats on top -->
    <div class="mirror-wrapper">
        <pre id="highlightLayer" class="highlight-layer" aria-hidden="true"><code id="highlightCode"></code></pre>
        <textarea id="codeEditor"
                  class="code-editor"
                  @oninput="OnCodeInput"
                  spellcheck="false"
                  placeholder="; Write Logo code here...">@_code
        </textarea>
    </div>
</div>

    <!-- ── RESIZE HANDLE ── -->
    <div class="resize-handle" id="resizeHandle">
        <div class="resize-grip"></div>
    </div>

    <!-- ── CANVAS PANE ── -->
    <div class="canvas-pane" id="canvasPane">
        <div class="pane-header">
            <MudIcon Icon="@Icons.Material.Filled.Brush" Size="Size.Small" />
            <MudText Typo="Typo.caption" Class="ml-1">Canvas</MudText>
            <MudSpacer />
            <MudIconButton Icon="@Icons.Material.Filled.Download"
                           Size="Size.Small" Title="Save image"
                           OnClick="SaveCanvas" />
        </div>
        <div class="canvas-wrapper">
            <canvas id="turtleCanvas"></canvas>
        </div>
    </div>

</div>

<!-- ═══════════════════════════ CONSOLE ═══════════════════════════ -->
<MudPaper Elevation="2" Class="console-pane" Square="true">
    <div class="d-flex align-center px-2 pt-1">
        <MudIcon Icon="@Icons.Material.Filled.Terminal" Size="Size.Small" />
        <MudText Typo="Typo.caption" Class="ml-1">Output</MudText>
        <MudSpacer />
        <MudIconButton Icon="@Icons.Material.Filled.DeleteSweep"
                       Size="Size.Small" Title="Clear console"
                       OnClick="() => _consoleLines.Clear()" />
    </div>
    <div class="console-output" id="consoleOutput">
        @foreach (var line in _consoleLines)
        {
            <div class="@(line.IsError ? "con-error" : line.IsSystem ? "con-system" : "con-normal")">
                <span class="con-prefix">@line.Prefix</span>@line.Text
            </div>
        }
    </div>
</MudPaper>

@code {

    // ── State ──────────────────────────────────────────────────────
    private string _code = string.Empty;
    private int _speed = 5;
    private bool _isRunning = false;
    private string _statusMessage = "Ready";

    private readonly List<ConsoleLine> _consoleLines = new();
    private IJSObjectReference? _jsModule;

    private CancellationTokenSource? _cts;

    // ── Lifecycle ──────────────────────────────────────────────────
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _jsModule = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./js/ideInterop.js");

            await _jsModule.InvokeVoidAsync("initCanvas", "turtleCanvas");
            await _jsModule.InvokeVoidAsync("initResizer", "resizeHandle", "editorPane", "canvasPane");
            await _jsModule.InvokeVoidAsync("initEditor", "codeEditor");   // ← new

            Log("▶  Logo IDE ready.", isSystem: true);
        }
    }

    // ── Toolbar Actions ────────────────────────────────────────────
    private async Task RunCode()
    {
        if (string.IsNullOrWhiteSpace(_code)) { Log("Nothing to run.", isSystem: true); return; }

        _cts           = new CancellationTokenSource();
        _isRunning     = true;
        _statusMessage = "Running...";
        _consoleLines.Clear();

        try
        {
            // Lex
            var lexer = new Lexer(_code);
            lexer.Tokenise();
            if (lexer.HasErrors)
            {
                foreach (var e in lexer.Errors) Log(e, isError: true);
                return;
            }

            // Parse
            var parser = new Parser(lexer.Tokens);
            var ast = parser.Parse();
            if (parser.HasErrors)
            {
                foreach (var e in parser.Errors) Log(e, isError: true);
                return;
            }

            // Run
            var interpreter = new Interpreter(
                js: _jsModule!,
                log: msg => Log(msg),
                logError: msg => Log(msg, isError: true),
                ct: _cts.Token,
                speed: _speed);

            await interpreter.RunAsync(ast);

            _statusMessage = "Done";
            Log("✔ Done.", isSystem: true);
        }
        catch (OperationCanceledException)
        {
            _statusMessage = "Stopped";
            Log("⏹ Stopped.", isSystem: true);
        }
        catch (RuntimeException ex)
        {
            _statusMessage = "Runtime error";
            Log(ex.Message, isError: true);
        }
        catch (Exception ex)
        {
            _statusMessage = "Error";
            Log($"Unexpected error: {ex.Message}", isError: true);
        }
        finally
        {
            _isRunning = false;
            _cts.Dispose();
            _cts = null;
            StateHasChanged();
        }
    }

    private void StopCode()
    {
        _cts?.Cancel();
    }

    private async Task ClearCanvas()
    {
        if (_jsModule is not null)
            await _jsModule.InvokeVoidAsync("clearCanvas");

        _statusMessage = "Ready";
        Log("Canvas cleared.", isSystem: true);
    }

    private async Task CopyCode()
    {
        if (_jsModule is not null)
            await _jsModule.InvokeVoidAsync("copyToClipboard", _code);
    }

    private async Task SaveCanvas()
    {
        if (_jsModule is not null)
            await _jsModule.InvokeVoidAsync("saveCanvasImage", "logo-drawing.png");
    }

    // ── Console Helpers ────────────────────────────────────────────
    private void Log(string text, bool isError = false, bool isSystem = false)
    {
        _consoleLines.Add(new ConsoleLine(
            Text: text,
            Prefix: isSystem ? "» " : isError ? "✖ " : "  ",
            IsError: isError,
            IsSystem: isSystem
        ));
        StateHasChanged();
    }

    // ── Cleanup ────────────────────────────────────────────────────
    public async ValueTask DisposeAsync()
    {
        if (_jsModule is not null)
            await _jsModule.DisposeAsync();
    }

    // ── Types ──────────────────────────────────────────────────────
    private record ConsoleLine(
        string Text,
        string Prefix = "  ",
        bool IsError = false,
        bool IsSystem = false
    );

    private void PrintNode(Node node, int depth)
    {
        var indent = new string(' ', depth * 2);
        var label = node switch
        {
            ProgramNode p => $"Program ({p.Statements.Count} statements)",
            RepeatNode _ => "Repeat",
            ForeverNode _ => "Forever",
            IfNode _ => "If",
            IfElseNode _ => "IfElse",
            WhileNode _ => "While",
            ForwardNode _ => "Forward",
            BackwardNode _ => "Backward",
            RightNode _ => "Right",
            LeftNode _ => "Left",
            HomeNode _ => "Home",
            PenUpNode _ => "PenUp",
            PenDownNode _ => "PenDown",
            SetColorNode _ => "SetColor",
            SetWidthNode _ => "SetWidth",
            ClearScreenNode _ => "ClearScreen",
            ProcDefNode p => $"ProcDef '{p.Name}' ({string.Join(", ", p.Params)})",
            ProcCallNode p => $"ProcCall '{p.Name}'",
            MakeNode m => $"Make \"{m.Name}",
            LocalNode l => $"Local \"{l.Name}",
            DerefNode d => $":{d.Name}",
            NumberNode n => $"Number {n.Value}",
            StringNode s => $"String \"{s.Value}",
            BooleanNode b => $"Boolean {b.Value}",
            BinaryOpNode b => $"BinaryOp '{b.Op}'",
            UnaryOpNode u => $"UnaryOp '{u.Op}'",
            StopNode _ => "Stop",
            OutputNode _ => "Output",
            _ => node.GetType().Name
        };

        Log($"{indent}{label}", isSystem: depth == 0);

        switch (node)
        {
            case ProgramNode p: foreach (var s in p.Statements) PrintNode(s, depth + 1); break;
            case RepeatNode r: PrintNode(r.Count, depth + 1); foreach (var s in r.Body) PrintNode(s, depth + 1); break;
            case ForeverNode f: foreach (var s in f.Body) PrintNode(s, depth + 1); break;
            case IfNode i: PrintNode(i.Condition, depth + 1); foreach (var s in i.Then) PrintNode(s, depth + 1); break;
            case IfElseNode i: PrintNode(i.Condition, depth + 1); foreach (var s in i.Then) PrintNode(s, depth + 1); foreach (var s in i.Else) PrintNode(s, depth + 1); break;
            case WhileNode w: PrintNode(w.Condition, depth + 1); foreach (var s in w.Body) PrintNode(s, depth + 1); break;
            case ForwardNode f: PrintNode(f.Distance, depth + 1); break;
            case BackwardNode b: PrintNode(b.Distance, depth + 1); break;
            case RightNode r: PrintNode(r.Degrees, depth + 1); break;
            case LeftNode l: PrintNode(l.Degrees, depth + 1); break;
            case SetColorNode c: PrintNode(c.Color, depth + 1); break;
            case SetWidthNode w: PrintNode(w.Width, depth + 1); break;
            case SetPosNode s: PrintNode(s.X, depth + 1); PrintNode(s.Y, depth + 1); break;
            case ProcDefNode p: foreach (var s in p.Body) PrintNode(s, depth + 1); break;
            case ProcCallNode p: foreach (var a in p.Args) PrintNode(a, depth + 1); break;
            case MakeNode m: PrintNode(m.Value, depth + 1); break;
            case OutputNode o: PrintNode(o.Value, depth + 1); break;
            case BinaryOpNode b: PrintNode(b.Left, depth + 1); PrintNode(b.Right, depth + 1); break;
            case UnaryOpNode u: PrintNode(u.Operand, depth + 1); break;
        }
    }
    private async Task OnCodeInput(ChangeEventArgs e)
    {
        _code = e.Value?.ToString() ?? string.Empty;
        if (_jsModule is not null)
            await _jsModule.InvokeVoidAsync("updateHighlight", _code);
    }
}